# =============================================================================
# Fixed benchmark assets + GPU (input/output dirs: use CLI --input_dir / --output_dir)
# =============================================================================
#
# Weights: put everything under ohbench/models/ (default). To use another directory:
# MODELS_ROOT="/path/to/models"
# MODELS_PATH="${MODELS_ROOT}"

# MODELS_ROOT="models"
MODELS_ROOT=""
MODELS_PATH="${MODELS_ROOT}"

# --- GT / benchmark data (edit paths for your machine) ---
# OHBENCH_DIR="ohbench_dir"
OHBENCH_DIR=""

# Match folder names inside ${OHBENCH_DIR}/ exactly.
# Custom reference images for video_quality
CUSTOM_IMAGE_FOLDER="${OHBENCH_DIR}/custom_image_folder"

# identity: single- / two-person reference face dirs (pair by basename with generated videos)
GT_SINGLE_DIR="${OHBENCH_DIR}/gt_single_dir"
GT_DOUBLE_DIR="${OHBENCH_DIR}/gt_double_dir"

# AV alignment: CSV (path, text, …)
AV_INPUT_CSV="${OHBENCH_DIR}/av_input.csv"

# Audio metrics: benchmark json + optional GT wav / reference images
AUDIO_QUALITY_BENCHMARK_DIR="${OHBENCH_DIR}/audio_quality_benchmark_dir"

# GPU: single card 0; multi 0,1,2,3 (comma-separated, no spaces)
EVAL_CUDA_DEVICES="0"
EVAL_TORCH_DEVICE="cuda:0"

# person_person (optional)
# PERSON_PERSON_MODEL="gemini-2.5-pro"
# PERSON_PERSON_API_BASE=""

# Optional: prebuilt single/double video list (basename,type). If set, person_person uses it.
VIDEO_TYPE_CSV="${OHBENCH_DIR}/video_types.csv"

